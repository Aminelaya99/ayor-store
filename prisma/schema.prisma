generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id           String   @id @default(cuid())
  customerName String
  phone        String
  wilaya       String
  product      String
  qty          Int      @default(1)
  shippingFee  Float    @default(600)
  totalPrice   Float
  status       String   @default("Pending") // 'Pending', 'Shipped', 'Delivered', 'Returned'
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ProductSettings {
  id           String      @id @default(cuid())
  name         String      @unique
  costPriceDzd Float       @default(0)
  sellingPrice Float       @default(0)
  initialStock Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  adExpenses   AdExpense[]
}

model AdExpense {
  id         String           @id @default(cuid())
  platform   String           // 'Facebook' | 'TikTok'
  spendUsd   Float
  spendDzd   Float
  date       DateTime         @default(now())
  productId  String?
  product    ProductSettings? @relation(fields: [productId], references: [id], onDelete: SetNull)
}
